{
  "name": "ecosphere",
  "version": "1.0.0",
  "description": "EcoSphere Auto-Pilot - AI-driven, gamified ESG operations platform",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --no-warnings server.js",
    "dev": "node --no-warnings --watch server.js",
    "seed": "node --no-warnings src/seed.js",
    "reset": "rm -f data/ecosphere.db && npm run seed",
    "make-admin": "node --no-warnings src/make-admin.js"
  }
}
