{
  "name": "ecosphere",
  "version": "1.0.0",
  "description": "EcoSphere Auto-Pilot - AI-driven, gamified ESG operations platform",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --no-warnings --env-file-if-exists=.env server.js",
    "dev": "node --no-warnings --env-file-if-exists=.env --watch server.js",
    "build:css": "node node_modules/tailwindcss/lib/cli.js -i ./src/input.css -o ./public/assets/output.css",
    "seed": "node --no-warnings --env-file-if-exists=.env src/seed.js",
    "reset": "rm -f data/ecosphere.db && npm run seed"
  },
  "dependencies": {
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.17",
    "tailwindcss": "^3.4.19"
  }
}
